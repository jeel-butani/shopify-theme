{%- style -%}
  #stack-smarter-{{ section.id }} {
    position: relative;
    width: 100%;
    min-height: 480px;
    overflow: hidden;
    display: flex;
    align-items: center;
  }

  #stack-smarter-{{ section.id }} .stack__media {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  #stack-smarter-{{ section.id }} .stack__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  #stack-smarter-{{ section.id }} .stack__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      90deg,
      rgba(0, 15, 5, 0.82) 0%,
      rgba(0, 20, 8, 0.7) 45%,
      rgba(0, 15, 5, 0.5) 70%,
      rgba(0, 10, 3, 0.35) 100%
    );
    z-index: 1;
  }

  #stack-smarter-{{ section.id }} .stack__content {
    position: relative;
    z-index: 2;
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: 60px 5%;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
    align-items: center;
  }

  #stack-smarter-{{ section.id }} .stack__text-col {
    color: #ffffff;
  }

  #stack-smarter-{{ section.id }} .stack__heading {
    font-family: 'DM Serif Display', 'Georgia', serif;
    font-size: clamp(26px, 3.5vw, 40px);
    font-weight: 400;
    line-height: 1.2;
    margin: 0 0 16px 0;
    color: #ffffff;
  }

  #stack-smarter-{{ section.id }} .stack__heading em,
  #stack-smarter-{{ section.id }} .stack__heading i {
    color: {{ section.settings.accent_color }};
    font-style: italic;
  }

  #stack-smarter-{{ section.id }} .stack__description {
    font-size: 15px;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.85);
    margin: 0 0 24px 0;
  }

  #stack-smarter-{{ section.id }} .stack__checklist {
    list-style: none;
    padding: 0;
    margin: 0 0 28px 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  #stack-smarter-{{ section.id }} .stack__checklist li {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 14px;
    color: rgba(255, 255, 255, 0.9);
    line-height: 1.5;
  }

  #stack-smarter-{{ section.id }} .stack__check-icon {
    width: 20px;
    height: 20px;
    min-width: 20px;
    background: {{ section.settings.accent_color }};
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  #stack-smarter-{{ section.id }} .stack__check-icon svg {
    width: 12px;
    height: 12px;
    fill: #ffffff;
  }

  #stack-smarter-{{ section.id }} .stack__cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 14px 32px;
    background: {{ section.settings.accent_color }};
    color: #ffffff;
    text-decoration: none;
    font-size: 14px;
    font-weight: 600;
    border-radius: 6px;
    transition: all 0.3s ease;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  #stack-smarter-{{ section.id }} .stack__cta:hover {
    background: {{ section.settings.accent_hover }};
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.25);
  }

  #stack-smarter-{{ section.id }} .stack__image-col {
    display: flex;
    justify-content: flex-end;
    align-items: center;
  }

  #stack-smarter-{{ section.id }} .stack__product-image {
    max-width: 320px;
    width: 100%;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.3);
  }

  #stack-smarter-{{ section.id }} .stack__product-image img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
  }

  @media (max-width: 768px) {
    #stack-smarter-{{ section.id }} .stack__content {
      grid-template-columns: 1fr;
      padding: 40px 5%;
    }

    #stack-smarter-{{ section.id }} .stack__image-col {
      justify-content: center;
    }

    #stack-smarter-{{ section.id }} .stack__product-image {
      max-width: 240px;
    }
  }
{%- endstyle -%}

<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display&display=swap" rel="stylesheet">

<section id="stack-smarter-{{ section.id }}">
  {%- if section.settings.background_image != blank -%}
    <div class="stack__media">
      {{ section.settings.background_image | image_url: width: 3840 | image_tag: sizes: '100vw', widths: '750, 1100, 1500, 2000, 3000, 3840' }}
    </div>
  {%- else -%}
    <div class="stack__media" style="background: linear-gradient(135deg, #1a2f1a 0%, #0d1f0d 100%);"></div>
  {%- endif -%}

  <div class="stack__overlay"></div>

  <div class="stack__content">
    <div class="stack__text-col">
      {%- if section.settings.heading != blank -%}
        <h2 class="stack__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}

      {%- if section.settings.description != blank -%}
        <p class="stack__description">{{ section.settings.description }}</p>
      {%- endif -%}

      {%- assign check_items = section.settings.checklist | split: '|' -%}
      {%- if check_items.size > 0 and section.settings.checklist != blank -%}
        <ul class="stack__checklist">
          {%- for item in check_items -%}
            <li>
              <span class="stack__check-icon">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
              </span>
              {{ item | strip }}
            </li>
          {%- endfor -%}
        </ul>
      {%- endif -%}

      {%- if section.settings.button_label != blank -%}
        <a href="{{ section.settings.button_link }}" class="stack__cta">
          {{ section.settings.button_label }}
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 4l-1.41 1.41L16.17 11H4v2h12.17l-5.58 5.59L12 20l8-8z"/></svg>
        </a>
      {%- endif -%}
    </div>

    <div class="stack__image-col">
      {%- if section.settings.product_image != blank -%}
        <div class="stack__product-image">
          {{ section.settings.product_image | image_url: width: 800 | image_tag: sizes: '(min-width: 768px) 320px, 240px', widths: '240, 320, 480, 640, 800' }}
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Stack Smarter",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Stack Smarter, <em>Feel Better.</em>"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Our synergy blends are crafted to work together — so you can build the optimal stack for gut health, energy, immunity, and beyond."
    },
    {
      "type": "textarea",
      "id": "checklist",
      "label": "Checklist items (separate with |)",
      "default": "Clinically researched ingredients|UK-made in GMP-certified facilities|100% natural, no artificial fillers|Designed for synergy — better together"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "BUILD YOUR STACK"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color",
      "default": "#2d7a3a"
    },
    {
      "type": "color",
      "id": "accent_hover",
      "label": "Accent hover color",
      "default": "#236830"
    },
    {
      "type": "image_picker",
      "id": "product_image",
      "label": "Product image (right side)"
    }
  ],
  "presets": [
    {
      "name": "Stack Smarter"
    }
  ]
}
{% endschema %}
