{%- style -%}
  #complete-routine-{{ section.id }} {
    background: {{ section.settings.background_color }};
    padding: 60px 0;
  }

  #complete-routine-{{ section.id }} .routine__inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 5%;
  }

  /* ── Header ── */
  #complete-routine-{{ section.id }} .routine__header {
    text-align: center;
    margin-bottom: 40px;
  }

  #complete-routine-{{ section.id }} .routine__heading {
    font-family: "Montserrat", sans-serif;
    font-size: clamp(30px, 4vw, 50px);
    font-weight: 700;
    letter-spacing: 0.5px;
    color: {{ section.settings.heading_color }};
    margin: 0 0 12px 0;
    line-height: 1.15;
  }

  /* "Complete Your" part — green */
  #complete-routine-{{ section.id }} .routine__heading .heading-main {
    color: #307e3d;
    font-style: normal;
  }

  /* "Routine" part — blue italic */
  #complete-routine-{{ section.id }} .routine__heading .heading-accent {
    color: #3b6db3;
    font-style: italic;
  }

  /* Fallback: keep em/i support too */
  #complete-routine-{{ section.id }} .routine__heading em,
  #complete-routine-{{ section.id }} .routine__heading i {
    font-style: italic;
    color: #3b6db3;
  }

  #complete-routine-{{ section.id }} .routine__subtitle {
    font-size: 15px;
    color: {{ section.settings.text_color }};
    max-width: 550px;
    margin: 0 auto;
    line-height: 1.6;
    opacity: 0.8;
  }

  /* ── Two-column grid ── */
  #complete-routine-{{ section.id }} .routine__grid {
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    gap: 40px;
    align-items: center;
  }

  /* ── Card (left) ── */
  #complete-routine-{{ section.id }} .routine__form-card {
    background: #ffffff;
    border-radius: 16px;
    padding: 32px 28px;
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.06);
    border: 1px solid #eee;
  }

  #complete-routine-{{ section.id }} .routine__form-title {
    font-family: "Montserrat", sans-serif;
    font-size: 20px;
    font-weight: 700;
    color: #1a1a1a;
    margin: 0 0 6px 0;
  }

  #complete-routine-{{ section.id }} .routine__form-subtitle {
    font-size: 13px;
    color: #888;
    margin: 0 0 24px 0;
    font-weight: 400;
  }

  /* ── Product rows ── */
  #complete-routine-{{ section.id }} .routine__form-items {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  #complete-routine-{{ section.id }} .routine__form-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    padding: 14px 16px;
    border-radius: 10px;
    background: #f8f9fa;
    border: 1px solid #ebebeb;
    transition: border-color 0.2s ease, background 0.2s ease;
  }

  #complete-routine-{{ section.id }} .routine__form-item:hover {
    border-color: {{ section.settings.accent_color }};
    background: #f2f8f2;
  }

  /* Product info (left side of row) */
  #complete-routine-{{ section.id }} .routine__item-info {
    display: flex;
    flex-direction: column;
    gap: 2px;
    flex: 1;
    min-width: 0;
  }

  #complete-routine-{{ section.id }} .routine__item-name {
    font-size: 14px;
    font-weight: 600;
    color: #1a1a1a;
    margin: 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  #complete-routine-{{ section.id }} .routine__item-price {
    font-size: 13px;
    color: #666;
    margin: 0;
    font-weight: 400;
  }

  /* "+ Add" button */
  #complete-routine-{{ section.id }} .routine__add-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 4px;
    background: #4a7c59;
    color: #ffffff;
    border: none;
    border-radius: 6px;
    padding: 8px 16px;
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    white-space: nowrap;
    flex-shrink: 0;
    transition: background 0.2s ease, transform 0.1s ease;
    font-family: "Montserrat", sans-serif;
    text-decoration: none;
  }

  #complete-routine-{{ section.id }} .routine__add-btn:hover {
    background: #3a6347;
    transform: translateY(-1px);
  }

  #complete-routine-{{ section.id }} .routine__add-btn:active {
    transform: translateY(0);
  }

  /* ── Image column (right) ── */
  #complete-routine-{{ section.id }} .routine__image-col {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  #complete-routine-{{ section.id }} .routine__product-img {
    width: 100%;
    max-width: 560px;
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 12px 48px rgba(0, 0, 0, 0.12);
  }

  #complete-routine-{{ section.id }} .routine__product-img img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    #complete-routine-{{ section.id }} {
      padding: 40px 0;
    }

    #complete-routine-{{ section.id }} .routine__grid {
      grid-template-columns: 1fr;
      gap: 28px;
    }

    /* Show image above card on mobile */
    #complete-routine-{{ section.id }} .routine__image-col {
      order: -1;
    }

    #complete-routine-{{ section.id }} .routine__product-img {
      max-width: 100%;
      border-radius: 14px;
    }

    #complete-routine-{{ section.id }} .routine__form-card {
      padding: 24px 18px;
    }
  }
{%- endstyle -%}

<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700;800&display=swap" rel="stylesheet">

<section id="complete-routine-{{ section.id }}">
  <div class="routine__inner">

    <!-- Header -->
    <div class="routine__header">
      {%- if section.settings.heading_before_accent != blank or section.settings.heading_accent != blank -%}
        <h2 class="routine__heading">
          <span class="heading-main">{{ section.settings.heading_before_accent }}</span>
          <em class="heading-accent">{{ section.settings.heading_accent }}</em>
        </h2>
      {%- endif -%}
      {%- if section.settings.subtitle != blank -%}
        <p class="routine__subtitle">{{ section.settings.subtitle }}</p>
      {%- endif -%}
    </div>

    <!-- Grid -->
    <div class="routine__grid">

      <!-- LEFT: Product list card -->
      <div class="routine__form-card">
        {%- if section.settings.form_title != blank -%}
          <h3 class="routine__form-title">{{ section.settings.form_title }}</h3>
        {%- endif -%}
        {%- if section.settings.form_subtitle != blank -%}
          <p class="routine__form-subtitle">{{ section.settings.form_subtitle }}</p>
        {%- endif -%}

        <ul class="routine__form-items">
          {%- for block in section.blocks -%}
            {%- assign product = all_products[block.settings.product_handle] -%}
            <li class="routine__form-item" {{ block.shopify_attributes }}>
              <div class="routine__item-info">
                <p class="routine__item-name">
                  {%- if product != blank -%}
                    {{ product.title }}
                  {%- else -%}
                    {{ block.settings.item_name }}
                  {%- endif -%}
                </p>
                <p class="routine__item-price">
                  {%- if product != blank -%}
                    {{ product.price | money }}
                  {%- elsif block.settings.item_price != blank -%}
                    {{ block.settings.item_price }}
                  {%- endif -%}
                </p>
              </div>
              {%- if product != blank -%}
                <a href="{{ product.url }}" class="routine__add-btn">+ Add</a>
              {%- elsif block.settings.product_url != blank -%}
                <a href="{{ block.settings.product_url }}" class="routine__add-btn">+ Add</a>
              {%- else -%}
                <button class="routine__add-btn" type="button">+ Add</button>
              {%- endif -%}
            </li>
          {%- endfor -%}
        </ul>
      </div>

      <!-- RIGHT: Product image -->
      <div class="routine__image-col">
        {%- if section.settings.product_image != blank -%}
          <div class="routine__product-img">
            {{ section.settings.product_image | image_url: width: 1120 | image_tag:
              loading: 'lazy',
              sizes: '(min-width: 768px) 560px, 100vw',
              widths: '400, 560, 800, 1000, 1120'
            }}
          </div>
        {%- endif -%}
      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Complete Routine",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "heading_before_accent",
      "label": "Heading — main words (green)",
      "default": "Complete Your"
    },
    {
      "type": "text",
      "id": "heading_accent",
      "label": "Heading — accent word (blue italic)",
      "default": "Routine"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Personalise your wellness stack with our science-backed pairings."
    },
    {
      "type": "header",
      "content": "Card"
    },
    {
      "type": "text",
      "id": "form_title",
      "label": "Form card title",
      "default": "Customize Your Routine"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#f8f8f6"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color (fallback)",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#555555"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent / hover color",
      "default": "#2d7a3a"
    },
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "product_image",
      "label": "Product image (right side)"
    }
  ],
  "blocks": [
    {
      "type": "product_item",
      "name": "Product Item",
      "settings": [
        {
          "type": "product",
          "id": "product_handle",
          "label": "Product",
          "info": "Select a product — name, price and link will be pulled automatically."
        },
        {
          "type": "text",
          "id": "item_name",
          "label": "Fallback name (if no product selected)",
          "default": "Product Name"
        },
        {
          "type": "text",
          "id": "item_price",
          "label": "Fallback price (if no product selected)",
          "default": "£29.99",
          "info": "e.g. £29.99 — only used when no product is selected above."
        },
        {
          "type": "url",
          "id": "product_url",
          "label": "Fallback URL (if no product selected)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Complete Routine",
      "blocks": [
        {
          "type": "product_item",
          "settings": {
            "item_name": "DigestiDetox Balance",
            "item_price": "£34.99"
          }
        },
        {
          "type": "product_item",
          "settings": {
            "item_name": "Probiotic Restore+",
            "item_price": "£29.99"
          }
        },
        {
          "type": "product_item",
          "settings": {
            "item_name": "Immunity Complex Pro",
            "item_price": "£29.99"
          }
        }
      ]
    }
  ]
}
{% endschema %}
