{{ 'about-custom.css' | asset_url | stylesheet_tag }}

<div class="about-core-values">
  <div class="page-width">
    <div class="values-header">
      <h2 class="values-title">
        {%- assign title_parts = section.settings.section_title | split: ' ' -%}
        {%- for part in title_parts -%}
          {%- if forloop.last -%}
            <span class="highlight-color">{{ part }}</span>
          {%- else -%}
            {{ part }} 
          {%- endif -%}
        {%- endfor -%}
      </h2>
      <p class="values-subtitle">{{ section.settings.section_subtitle }}</p>
    </div>

    <div class="values-grid">
      {%- for block in section.blocks -%}
        <div class="value-card" {{ block.shopify_attributes }}>
          <h3 class="value-title">{{ block.settings.title }}</h3>
          <p class="value-description">{{ block.settings.description }}</p>
          {%- if block.settings.link_url != blank -%}
            <a href="{{ block.settings.link_url }}" class="value-link">
              {{ block.settings.link_text | default: 'Learn more' }}
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
            </a>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "About - Core Values",
  "settings": [
    {
      "type": "text",
      "id": "section_title",
      "label": "Section Title",
      "default": "Our Core Values"
    },
    {
      "type": "textarea",
      "id": "section_subtitle",
      "label": "Section Subtitle",
      "default": "The principles that guide every decision we make — from formulation to packaging."
    }
  ],
  "blocks": [
    {
      "type": "value_card",
      "name": "Value Card",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Science First"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Every decision is grounded in rigorous scientific evidence and peer-reviewed research."
        },
        {
          "type": "url",
          "id": "link_url",
          "label": "Link URL"
        },
        {
          "type": "text",
          "id": "link_text",
          "label": "Link Text",
          "default": "Learn more"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "About - Core Values",
      "blocks": [
        {
          "type": "value_card",
          "settings": {
            "title": "Science First"
          }
        },
        {
          "type": "value_card",
          "settings": {
            "title": "Botanical Purity"
          }
        },
        {
          "type": "value_card",
          "settings": {
            "title": "Sustainability"
          }
        },
        {
          "type": "value_card",
          "settings": {
            "title": "Radical Transparency"
          }
        }
      ]
    }
  ]
}
{% endschema %}

