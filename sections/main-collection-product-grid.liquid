{{ 'template-collection.css' | asset_url | stylesheet_tag }}
{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}

{% if section.settings.image_shape == 'blob' %}
  {{ 'mask-blobs.css' | asset_url | stylesheet_tag }}
{%- endif -%}

{%- unless section.settings.quick_add == 'none' -%}
  {{ 'quick-add.css' | asset_url | stylesheet_tag }}
{%- endunless -%}

{%- if section.settings.quick_add == 'standard' -%}
  <script src="{{ 'quick-add.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

{%- if section.settings.quick_add == 'bulk' -%}
  <script src="{{ 'quick-add-bulk.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'quantity-popover.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'price-per-item.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'quick-order-list.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  .section-{{ section.id }}-padding .collection-toolbar-shell {
    position: sticky;
    top: 0;
    z-index: 4;
  }

  .section-{{ section.id }}-padding .collection-toolbar-spacer {
    height: 1.2rem;
  }

  .section-{{ section.id }}-padding .collection-view-controls {
    display: inline-flex;
    align-items: center;
    gap: 0.8rem;
  }

  .section-{{ section.id }}-padding .collection-view-button {
    width: 3.8rem;
    height: 3.8rem;
    border: 0.1rem solid rgba(71, 81, 60, 0.18);
    border-radius: 0.8rem;
    background: #f6f6ef;
    color: #59614e;
    cursor: pointer;
    transition: background-color 0.2s ease, border-color 0.2s ease, color 0.2s ease;
  }

  .section-{{ section.id }}-padding .collection-view-button.is-active {
    background: #f0f2e8;
    border-color: rgba(71, 81, 60, 0.34);
    color: #3c4331;
  }

  .section-{{ section.id }}-padding .collection-view-button svg {
    width: 1.8rem;
    height: 1.8rem;
  }

  .section-{{ section.id }}-padding .collection-search {
    position: relative;
    min-width: 18rem;
  }

  .section-{{ section.id }}-padding .collection-search__icon {
    position: absolute;
    left: 1.2rem;
    top: 50%;
    transform: translateY(-50%);
    color: rgba(73, 83, 61, 0.55);
    pointer-events: none;
  }

  .section-{{ section.id }}-padding .collection-search__icon svg {
    width: 1.5rem;
    height: 1.5rem;
  }

  .section-{{ section.id }}-padding .collection-search__input {
    width: 100%;
    min-height: 3.8rem;
    padding: 0.9rem 1.2rem 0.9rem 3.6rem;
    border: 0.1rem solid rgba(71, 81, 60, 0.12);
    border-radius: 0.8rem;
    background: #f1f3eb;
    color: #49533d;
    font-size: 1rem;
    box-shadow: none;
  }

  .section-{{ section.id }}-padding .collection-search__input::placeholder {
    color: rgba(73, 83, 61, 0.56);
  }

  .section-{{ section.id }}-padding .collection-grid-container.collection-grid-container--list #product-grid {
    grid-template-columns: 1fr;
  }

  .section-{{ section.id }}-padding .collection-grid-container.collection-grid-container--list #product-grid > .grid__item {
    width: 100%;
    max-width: 100%;
  }

  .product-page-width {
    max-width: 100%;
    padding-left: 12px;
    padding-right: 12px;
  }

  /* Tablet */
  @media (min-width: 750px) {
    .product-page-width {
      padding-left: 20px;
      padding-right: 20px;
    }
  }

  /* Desktop */
  @media (min-width: 1200px) {
    .product-page-width {
      padding-left: 10vw;
      padding-right: 10vw;
    }
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="section-{{ section.id }}-padding gradient color-{{ section.settings.color_scheme }}">
  {%- paginate collection.products by section.settings.products_per_page -%}
    {% comment %} Sort is the first tabbable element when filter type is vertical {% endcomment %}
    {%- if section.settings.enable_sorting and section.settings.filter_type == 'vertical' -%}
      <facet-filters-form class="facets facets-vertical-sort page-width small-hide">
        <form class="facets-vertical-form" id="FacetSortForm">
          <div class="facet-filters sorting caption">
            <div class="facet-filters__field">
              <div class="select">
                {%- assign sort_by = collection.sort_by | default: collection.default_sort_by -%}
                <select
                  name="sort_by"
                  class="facet-filters__sort select__select caption-large"
                  id="SortBy"
                  aria-describedby="a11y-refresh-page-message"
                >
                  {%- for option in collection.sort_options -%}
                    <option
                      value="{{ option.value | escape }}"
                      {% if option.value == sort_by %}
                        selected="selected"
                      {% endif %}
                    >
                      {{ option.name | escape }}
                    </option>
                  {%- endfor -%}
                </select>
                <span class="svg-wrapper">
                  {{- 'icon-caret.svg' | inline_asset_content -}}
                </span>
              </div>
            </div>
          </div>

          <div class="product-count-vertical light" role="status">
            <h2 class="product-count__text text-body">
              <span id="ProductCountDesktop">
                {%- if collection.results_count -%}
                  {{
                    'templates.search.results_with_count'
                    | t: terms: collection.terms, count: collection.results_count
                  }}
                {%- elsif collection.products_count == collection.all_products_count -%}
                  {{ 'products.facets.product_count_simple' | t: count: collection.products_count }}
                {%- else -%}
                  {{
                    'products.facets.product_count'
                    | t: product_count: collection.products_count, count: collection.all_products_count
                  }}
                {%- endif -%}
              </span>
            </h2>
            {%- render 'loading-spinner' -%}
          </div>
        </form>
      </facet-filters-form>
    {%- endif -%}

    <div class="{% if section.settings.filter_type == 'vertical' %} facets-vertical page-width{% endif %}">
      {{ 'component-facets.css' | asset_url | stylesheet_tag }}
      <script src="{{ 'facets.js' | asset_url }}" defer="defer"></script>
      {%- if section.settings.enable_filtering or section.settings.enable_sorting -%}
        <aside
          aria-labelledby="verticalTitle"
          class="facets-wrapper{% unless section.settings.enable_filtering %} facets-wrapper--no-filters{% endunless %}{% if section.settings.filter_type != 'vertical' %} page-width{% endif %}"
          id="main-collection-filters"
          data-id="{{ section.id }}"
        >
          {% render 'facets',
            results: collection,
            enable_filtering: section.settings.enable_filtering,
            enable_sorting: section.settings.enable_sorting,
            filter_type: section.settings.filter_type,
            paginate: paginate
          %}
        </aside>
      {%- endif -%}

      <div
      class="product-grid-container{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
        id="ProductGridContainer"
        {% if settings.animations_reveal_on_scroll %}
          data-cascade
        {% endif %}
      >
        <div class="collection-toolbar-spacer"></div>
        {%- if collection.products.size == 0 -%}
          <div class="collection collection--empty page-width" id="product-grid" data-id="{{ section.id }}">
            <div class="loading-overlay gradient"></div>
            <div class="title-wrapper center">
              <h2 class="title title--primary">
                {{ 'sections.collection_template.empty' | t -}}
                <br>
                {{
                  'sections.collection_template.use_fewer_filters_html'
                  | t: link: collection.url, class: 'underlined-link link'
                }}
              </h2>
            </div>
          </div>
        {%- else -%}
          <div
            class="collection{% if section.settings.filter_type != 'vertical' %} product-page-width{% endif %}"
          >
            <div class="loading-overlay gradient"></div>
            <ul
              id="product-grid"
              data-id="{{ section.id }}"
              class="
                grid product-grid grid--{{ section.settings.columns_mobile }}-col-tablet-down
                grid--{{ section.settings.columns_desktop }}-col-desktop
                {% if section.settings.quick_add == 'bulk' %} collection-quick-add-bulk{% endif %}
              "
            >
              {% assign skip_card_product_styles = false %}
              {%- for product in collection.products -%}
                {% assign lazy_load = false %}
                {%- if forloop.index > 2 -%}
                  {%- assign lazy_load = true -%}
                {%- endif -%}
                <li
                  class="grid__item{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
                  data-product-title="{{ product.title | escape }}"
                  data-product-type="{{ product.type | escape }}"
                  data-product-text="{{ product.description | strip_html | strip_newlines | escape }}"
                  {% if settings.animations_reveal_on_scroll %}
                    data-cascade
                    style="--animation-order: {{ forloop.index }};"
                  {% endif %}
                >
                  {% render 'card-product',
                    card_product: product,
                    media_aspect_ratio: section.settings.image_ratio,
                    image_shape: section.settings.image_shape,
                    show_secondary_image: section.settings.show_secondary_image,
                    show_vendor: section.settings.show_vendor,
                    show_rating: section.settings.show_rating,
                    lazy_load: lazy_load,
                    skip_styles: skip_card_product_styles,
                    quick_add: section.settings.quick_add,
                    section_id: section.id,
                    collection_card: true
                  %}
                </li>
                {%- assign skip_card_product_styles = true -%}
              {%- endfor -%}
            </ul>

            {%- if paginate.pages > 1 -%}
              {% render 'pagination', paginate: paginate, anchor: '' %}
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>
    </div>
  {%- endpaginate -%}
  {% if section.settings.image_shape == 'arch' %}
    {{ 'mask-arch.svg' | inline_asset_content }}
  {%- endif -%}
</div>

<script>
  (() => {
    const sectionRoot = document.querySelector('#shopify-section-{{ section.id }}');
    if (!sectionRoot) return;

    const initCollectionTools = () => {
      const toolbar = sectionRoot.querySelector('.facets-container');
      const gridContainer = sectionRoot.querySelector('#ProductGridContainer');
      const productGrid = sectionRoot.querySelector('#product-grid');

      if (!toolbar || !gridContainer || !productGrid || toolbar.dataset.collectionToolbarReady === 'true') return;
      toolbar.dataset.collectionToolbarReady = 'true';
      gridContainer.classList.add('collection-grid-container');

      const productCountNode =
        toolbar.querySelector('#ProductCountDesktop') ||
        toolbar.querySelector('#ProductCount') ||
        sectionRoot.querySelector('#ProductCountDesktop') ||
        sectionRoot.querySelector('#ProductCount');

      const productCountText = productCountNode ? productCountNode.textContent.trim() : '';

      const shell = document.createElement('div');
      shell.className = 'collection-toolbar-shell';

      const right = document.createElement('div');
      right.className = 'collection-toolbar-right';

      const searchWrap = document.createElement('div');
      searchWrap.className = 'collection-search';
      searchWrap.innerHTML = `
        <span class="collection-search__icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
            <circle cx="11" cy="11" r="6.5"></circle>
            <path d="M16 16L21 21"></path>
          </svg>
        </span>
        <input class="collection-search__input" type="search" placeholder="Search products..." aria-label="Search products">
      `;

      const count = document.createElement('div');
      count.className = 'collection-toolbar-count';
      count.textContent = productCountText;

      const viewControls = document.createElement('div');
      viewControls.className = 'collection-view-controls';
      viewControls.innerHTML = `
        <button type="button" class="collection-view-button is-active" data-view="grid" aria-label="Grid view">
          <svg viewBox="0 0 24 24" fill="currentColor">
            <rect x="4" y="4" width="6" height="6" rx="1"></rect>
            <rect x="14" y="4" width="6" height="6" rx="1"></rect>
            <rect x="4" y="14" width="6" height="6" rx="1"></rect>
            <rect x="14" y="14" width="6" height="6" rx="1"></rect>
          </svg>
        </button>
        <button type="button" class="collection-view-button" data-view="list" aria-label="List view">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
            <path d="M6 7H20"></path>
            <path d="M6 12H20"></path>
            <path d="M6 17H20"></path>
            <circle cx="4" cy="7" r="1"></circle>
            <circle cx="4" cy="12" r="1"></circle>
            <circle cx="4" cy="17" r="1"></circle>
          </svg>
        </button>
      `;

      right.append(searchWrap, count, viewControls);
      shell.append(toolbar);
      toolbar.append(right);
      gridContainer.prepend(shell);

      const items = Array.from(productGrid.querySelectorAll('.grid__item'));
      const searchInput = shell.querySelector('.collection-search__input');
      const countLabel = count;

      const syncCount = (visibleCount) => {
        const normalized = productCountText.replace(/\d+ products?/i, `${visibleCount} products`);
        countLabel.textContent = normalized || `${visibleCount} products`;
      };

      const applySearch = () => {
        const term = searchInput.value.trim().toLowerCase();
        let visible = 0;

        items.forEach((item) => {
          const haystack = [
            item.dataset.productTitle || '',
            item.dataset.productType || '',
            item.dataset.productText || ''
          ]
            .join(' ')
            .toLowerCase();

          const match = term === '' || haystack.includes(term);
          item.style.display = match ? '' : 'none';
          if (match) visible += 1;
        });

        syncCount(visible);
      };

      searchInput.addEventListener('input', applySearch);

      viewControls.querySelectorAll('.collection-view-button').forEach((button) => {
        button.addEventListener('click', () => {
          const view = button.dataset.view;
          gridContainer.classList.toggle('collection-grid-container--list', view === 'list');
          viewControls.querySelectorAll('.collection-view-button').forEach((node) => {
            node.classList.toggle('is-active', node === button);
          });
        });
      });

      productGrid.addEventListener('click', (event) => {
        const button = event.target.closest('[data-qty-minus], [data-qty-plus]');
        if (!button) return;

        const control = button.closest('[data-qty-control]');
        const input = control ? control.querySelector('.card__collection-qty-input') : null;
        if (!input) return;

        const current = parseInt(input.value || '1', 10);
        const next = button.hasAttribute('data-qty-plus') ? current + 1 : Math.max(1, current - 1);
        input.value = next;
        input.dispatchEvent(new Event('input', { bubbles: true }));
      });

      productGrid.addEventListener('input', (event) => {
        if (!event.target.classList.contains('card__collection-qty-input')) return;
        const input = event.target;
        const normalized = Math.max(1, parseInt(input.value || '1', 10) || 1);
        input.value = normalized;

        const card = input.closest('.card--collection-custom');
        const hidden = card ? card.querySelector('.card__collection-qty-hidden') : null;
        if (hidden) hidden.value = normalized;
      });

      syncCount(items.length);
    };

    initCollectionTools();

    const observer = new MutationObserver(() => {
      initCollectionTools();
    });

    observer.observe(sectionRoot, { childList: true, subtree: true });
  })();
</script>

