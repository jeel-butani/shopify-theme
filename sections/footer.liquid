{% comment %}theme-check-disable UndefinedObject{% endcomment %}
{{ 'section-footer.css' | asset_url | stylesheet_tag }}
{{ 'component-newsletter.css' | asset_url | stylesheet_tag }}
{{ 'component-list-menu.css' | asset_url | stylesheet_tag }}
{{ 'component-list-payment.css' | asset_url | stylesheet_tag }}
{{ 'component-list-social.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .footer {
    margin-top: {{ section.settings.margin_top | times: 0.75 | round: 0 }}px;
  }

  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  .footer--custom {
    --footer-bg: #071f28;
    --footer-overlay: {{ section.settings.background_overlay | default: 72 | divided_by: 100.0 }};
    --footer-line: rgba(255, 255, 255, 0.2);
    --footer-soft: rgba(255, 255, 255, 0.72);
    --footer-muted: rgba(255, 255, 255, 0.58);
    --footer-panel: rgba(2, 18, 24, 0.62);
    position: relative;
    overflow: hidden;
    border-top: 0;
    color: #ffffff;
    background:
      linear-gradient(rgba(4, 21, 29, var(--footer-overlay)), rgba(4, 21, 29, var(--footer-overlay))),
      radial-gradient(circle at top left, rgba(26, 109, 140, 0.18), transparent 34%),
      radial-gradient(circle at top right, rgba(50, 145, 171, 0.14), transparent 28%),
      var(--footer-bg);
  }

  .page-width {
    max-width: 100%;
    padding-left: 12px;
    padding-right: 12px;
  }

  /* Tablet */
  @media (min-width: 750px) {
    .page-width {
      padding-left: 20px;
      padding-right: 20px;
    }
  }

  /* Desktop */
  @media (min-width: 1200px) {
    .page-width {
      padding-left: 40px;
      padding-right: 40px;
    }
  }

  .footer--custom.footer--has-bg {
    background:
      linear-gradient(rgba(4, 21, 29, var(--footer-overlay)), rgba(4, 21, 29, calc(var(--footer-overlay) + 0.06))),
      var(--footer-bg-image) center/cover no-repeat,
      var(--footer-bg);
  }

  .footer--custom.gradient {
    background-attachment: scroll;
  }

  .footer--custom .page-width {
    position: relative;
    z-index: 1;
  }

  .footer--custom .footer__content-top {
    padding-bottom: 0;
  }

  .footer--custom .footer__panel {
    padding: 1rem 0 0;
  }

  .footer--custom .footer__main-grid {
    display: grid;
    grid-template-columns: minmax(24rem, 1.25fr) minmax(36rem, 2fr) minmax(28rem, 1.1fr);
    gap: 4rem;
    align-items: start;
  }

  .footer--custom .footer__brand-column,
  .footer--custom .footer__newsletter-panel,
  .footer--custom .footer__nav-columns,
  .footer--custom .footer__menu-column {
    color: #ffffff;
  }

  .footer--custom .footer__brand-column {
    max-width: 30rem;
  }

  .footer--custom .footer-block__image-wrapper {
    margin-bottom: 2rem;
  }

  .footer--custom .footer-block__image-wrapper img {
    max-height: 6rem;
    width: auto;
  }

  .footer--custom .footer__brand-copy,
  .footer--custom .footer-block__details-content,
  .footer--custom .footer__newsletter-text,
  .footer--custom .footer__meta-copy {
    font-size: 1rem;
    line-height: 1.85;
    color: var(--footer-soft);
  }

  .footer--custom .footer__brand-copy p,
  .footer--custom .footer__meta-copy p {
    margin: 0;
  }

  .footer--custom .footer__list-social.list-social {
    justify-content: flex-start;
    gap: 0.8rem;
    margin-top: 2rem;
  }

  .footer--custom .list-social__link {
    width: 3.6rem;
    height: 3.6rem;
    padding: 0;
    border: 0.1rem solid rgba(255, 255, 255, 0.58);
    border-radius: 50%;
    justify-content: center;
    color: #ffffff;
    transition: transform 0.2s ease, border-color 0.2s ease, background-color 0.2s ease;
  }

  .footer--custom .list-social__link:hover {
    transform: translateY(-0.1rem);
    border-color: #ffffff;
    background-color: rgba(255, 255, 255, 0.08);
  }

  .footer--custom .list-social__link .icon {
    width: 1.6rem;
    height: 1.6rem;
  }

  .footer--custom .footer__nav-columns {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 3rem;
  }

  .footer--custom .footer__menu-column {
    min-width: 0;
  }

  .footer--custom .footer-block__heading {
    margin: 0 0 1.8rem;
    font-size: 1.55rem;
    font-weight: 700;
    color: #ffffff;
    letter-spacing: 0;
  }

  .footer--custom .footer-block__details-content {
    margin-bottom: 0;
  }

  .footer--custom .list-menu__item--link {
    display: inline-block;
    padding: 0.35rem 0;
    color: var(--footer-soft);
    text-decoration: none;
    font-size: 1.32rem;
    line-height: 1.6;
  }

  .footer--custom .list-menu__item--link:hover,
  .footer--custom .copyright__content a:hover,
  .footer--custom .policies a:hover {
    color: #ffffff;
  }

  .footer--custom .footer__newsletter-panel {
    max-width: 32rem;
    justify-self: end;
  }

  .footer--custom .footer__newsletter-label {
    display: inline-block;
    margin-bottom: 1rem;
    color: rgba(255, 255, 255, 0.88);
    font-size: 1.05rem;
    letter-spacing: 0.18rem;
    text-transform: uppercase;
  }

  .footer--custom .footer__newsletter-panel .footer-block__heading {
    font-size: 1.4rem;
    font-weight: 500;
    margin-bottom: 1rem;
  }

  .footer--custom .footer__newsletter-text {
    margin-bottom: 1.6rem;
    font-size: 1.2rem;
    line-height: 1.7;
  }

  .footer--custom .footer__newsletter .field {
    position: relative;
    display: block;
  }

  .footer--custom .footer__newsletter .field:after,
  .footer--custom .footer__newsletter .field:before {
    display: none;
  }

  .footer--custom .field__input {
    min-height: 5rem;
    padding: 1.4rem 1.6rem;
    border: 0.1rem solid rgba(255, 255, 255, 0.58);
    border-radius: 0;
    background: rgba(5, 20, 27, 0.38);
    color: #ffffff;
    box-shadow: none;
  }

  .footer--custom .field__input::placeholder {
    color: rgba(255, 255, 255, 0.65);
  }

  .footer--custom .field__label {
    display: none;
  }

  .footer--custom .footer__newsletter-button {
    width: 100%;
    min-height: 5rem;
    margin-top: 1.4rem;
    border: 0.1rem solid rgba(255, 255, 255, 0.72);
    background: transparent;
    color: #ffffff;
    font-size: 1.22rem;
    font-weight: 600;
    letter-spacing: 0.08rem;
    text-transform: uppercase;
    cursor: pointer;
    transition: background-color 0.2s ease, color 0.2s ease;
  }

  .footer--custom .footer__newsletter-button:hover {
    background: #ffffff;
    color: #081c24;
  }

  .footer--custom .newsletter-form__message {
    margin-top: 1rem;
    color: #ffffff;
  }

  .footer--custom .footer__midline {
    height: 0.1rem;
    margin: 3rem 0 1.8rem;
    background: var(--footer-line);
  }

  .footer--custom .footer__meta-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    padding-bottom: 1.6rem;
  }

  .footer--custom .footer__meta-copy {
    max-width: 68rem;
    font-size: 1.12rem;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.7);
  }

  .footer--custom .footer__trust-badges {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 0.8rem;
  }

  .footer--custom .footer__trust-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.8rem;
    padding: 0.5rem 1rem;
    border: 0.1rem solid rgba(255, 255, 255, 0.6);
    border-radius: 0.3rem;
    font-size: 1rem;
    line-height: 1;
    letter-spacing: 0.08rem;
    text-transform: uppercase;
    color: #ffffff;
  }

  .footer--custom .footer__content-bottom {
    border-top: 0;
    padding-top: 0.8rem;
  }

  .footer--custom .footer__content-bottom-wrapper {
    justify-content: center;
  }

  .footer--custom .footer__column,
  .footer--custom .footer__column--info {
    width: auto;
    padding: 0;
    align-items: center;
  }

  .footer--custom .footer__payment {
    margin-top: 0;
  }

  .footer--custom .list-payment {
    justify-content: center;
    gap: 1rem;
  }

  .footer--custom .footer__copyright {
    margin-top: 1.6rem;
    text-align: center;
  }

  .footer--custom .copyright__content,
  .footer--custom .policies li a {
    color: rgba(255, 255, 255, 0.72);
    font-size: 1.1rem;
  }

  .footer--custom .policies li::before {
    color: rgba(255, 255, 255, 0.45);
  }

  .footer--custom .footer__extras {
    margin-top: 2.4rem;
  }

  .footer--custom .footer__extras .footer-block {
    color: var(--footer-soft);
  }

  @media screen and (min-width: 750px) {
    .footer {
      margin-top: {{ section.settings.margin_top }}px;
    }

    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  @media screen and (max-width: 989px) {
    .footer--custom .footer__main-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }

    .footer--custom .footer__brand-column,
    .footer--custom .footer__newsletter-panel {
      max-width: none;
      justify-self: stretch;
    }

    .footer--custom .footer__nav-columns {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .footer--custom .footer__meta-row {
      flex-direction: column;
      align-items: flex-start;
    }

    .footer--custom .footer__trust-badges {
      justify-content: flex-start;
    }
  }

  @media screen and (max-width: 749px) {
    .footer--custom .footer__content-top {
      padding-left: 0;
      padding-right: 0;
    }

    .footer--custom .footer__panel {
      padding-top: 0;
    }

    .footer--custom .footer__main-grid {
      gap: 2.8rem;
    }

    .footer--custom .footer__nav-columns {
      grid-template-columns: 1fr;
      gap: 2.2rem;
    }

    .footer--custom .footer__newsletter-panel {
      order: 4;
    }

    .footer--custom .footer__brand-copy,
    .footer--custom .footer__newsletter-text,
    .footer--custom .footer__meta-copy,
    .footer--custom .footer-block__details-content {
      font-size: 1.28rem;
      line-height: 1.8;
    }

    .footer--custom .footer__midline {
      margin: 2.4rem 0 1.6rem;
    }

    .footer--custom .footer__content-bottom {
      padding-top: 0.2rem;
    }

    .footer--custom .footer__content-bottom-wrapper {
      row-gap: 0;
    }
  }
{%- endstyle -%}

{%- liquid
  assign has_social_icons = true
  if settings.social_facebook_link == blank and settings.social_instagram_link == blank and settings.social_youtube_link == blank and settings.social_tiktok_link == blank and settings.social_twitter_link == blank and settings.social_pinterest_link == blank and settings.social_snapchat_link == blank and settings.social_tumblr_link == blank and settings.social_vimeo_link == blank
    assign has_social_icons = false
  endif

  if settings.brand_image == blank and settings.brand_headline == blank and settings.brand_description == blank
    assign brand_empty = true
  endif

  if section.blocks.size == 1 and section.blocks[0].type == 'brand_information' and brand_empty and has_social_icons == false and section.settings.newsletter_enable == false and section.settings.enable_follow_on_shop == false
    assign only_empty_brand = true
  endif

  assign trust_badges = section.settings.trust_badges | newline_to_br | replace: '<br />', ',' | split: ','
  assign footer_has_bg = false
  if section.settings.background_image != blank
    assign footer_has_bg = true
  endif
-%}

{%- capture brand_block_markup -%}
  {%- for block in section.blocks -%}
    {%- if block.type == 'brand_information' -%}
      <div class="footer__brand-column footer-block" {{ block.shopify_attributes }}>
        <div class="footer-block__brand-info">
          {%- if settings.brand_image != blank -%}
            {%- assign brand_image_height = settings.brand_image_width | divided_by: settings.brand_image.aspect_ratio -%}
            <div
              class="footer-block__image-wrapper"
              style="max-width: min(100%, {{ settings.brand_image_width }}px);"
            >
              {{
                settings.brand_image
                | image_url: width: 1100
                | image_tag:
                  loading: 'lazy',
                  widths: '50, 100, 150, 200, 300, 400, 550, 800, 1100',
                  height: brand_image_height,
                  width: settings.brand_image_width
              }}
            </div>
          {%- endif -%}

          {%- if settings.brand_headline != blank -%}
            <h2 class="footer-block__heading rte">{{ settings.brand_headline }}</h2>
          {%- endif -%}

          {%- if settings.brand_description != blank -%}
            <div class="footer__brand-copy rte">{{ settings.brand_description }}</div>
          {%- endif -%}

          {%- if block.settings.show_social and has_social_icons -%}
            {%- render 'social-icons', class: 'footer__list-social' -%}
          {%- endif -%}
        </div>
      </div>
    {%- endif -%}
  {%- endfor -%}
{%- endcapture -%}

{%- capture menu_blocks_markup -%}
  {%- for block in section.blocks -%}
    {%- if block.type == 'link_list' and block.settings.menu != blank -%}
      <div class="footer__menu-column footer-block footer-block--menu" {{ block.shopify_attributes }}>
        {%- if block.settings.heading != blank -%}
          <h2 class="footer-block__heading inline-richtext">{{- block.settings.heading -}}</h2>
        {%- endif -%}
        <ul class="footer-block__details-content list-unstyled">
          {%- for link in block.settings.menu.links -%}
            <li>
              <a
                href="{{ link.url }}"
                class="link link--text list-menu__item list-menu__item--link{% if link.active %} list-menu__item--active{% endif %}"
              >
                {{ link.title | escape }}
              </a>
            </li>
          {%- endfor -%}
        </ul>
      </div>
    {%- endif -%}
  {%- endfor -%}
{%- endcapture -%}

{%- capture extra_blocks_markup -%}
  {%- for block in section.blocks -%}
    {%- case block.type -%}
      {%- when 'text' -%}
        <div class="footer-block" {{ block.shopify_attributes }}>
          {%- if block.settings.heading != blank -%}
            <h2 class="footer-block__heading inline-richtext">{{- block.settings.heading -}}</h2>
          {%- endif -%}
          <div class="footer-block__details-content rte">
            {{ block.settings.subtext }}
          </div>
        </div>
      {%- when 'image' -%}
        <div class="footer-block" {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            {%- assign image_size_2x = block.settings.image_width | times: 2 | at_most: 5760 -%}
            <div
              class="footer-block__image-wrapper"
              style="max-width: min(100%, {{ block.settings.image_width }}px);"
            >
              <img
                srcset="{{ block.settings.image | image_url: width: block.settings.image_width }}, {{ block.settings.image | image_url: width: image_size_2x }} 2x"
                src="{{ block.settings.image | image_url: width: 760 }}"
                alt="{{ block.settings.image.alt | escape }}"
                loading="lazy"
                width="{{ block.settings.image.width }}"
                height="{{ block.settings.image.height }}"
              >
            </div>
          {%- endif -%}
        </div>
      {%- when '@app' -%}
        <div class="footer-block" {{ block.shopify_attributes }}>
          {% render block %}
        </div>
    {%- endcase -%}
  {%- endfor -%}
{%- endcapture -%}

<footer
  class="footer footer--custom color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding{% if footer_has_bg %} footer--has-bg{% endif %}"
  {% if footer_has_bg %}
    style="--footer-bg-image: url('{{ section.settings.background_image | image_url: width: 2200 }}');"
  {% endif %}
>
  <div class="page-width">
    {%- if section.blocks.size > 0 or section.settings.newsletter_enable or section.settings.payment_enable or section.settings.show_policy -%}
      {%- unless only_empty_brand -%}
        <div class="footer__content-top">
          <div class="footer__panel">
            <div class="footer__main-grid">
              {{ brand_block_markup }}

              {%- if menu_blocks_markup != blank -%}
                <div class="footer__nav-columns">
                  {{ menu_blocks_markup }}
                </div>
              {%- endif -%}

              {%- if section.settings.newsletter_enable -%}
                <div class="footer__newsletter-panel footer-block--newsletter">
                  <div class="footer-block__newsletter">
                    <span class="footer__newsletter-label">Newsletter</span>

                    {%- if section.settings.newsletter_heading != blank -%}
                      <h2 class="footer-block__heading inline-richtext">{{ section.settings.newsletter_heading }}</h2>
                    {%- endif -%}

                    {%- if section.settings.newsletter_text != blank -%}
                      <div class="footer__newsletter-text">{{ section.settings.newsletter_text | escape | newline_to_br }}</div>
                    {%- endif -%}

                    {%- form 'customer', id: 'ContactFooter', class: 'footer__newsletter newsletter-form' -%}
                      <input type="hidden" name="contact[tags]" value="newsletter">
                      <div class="newsletter-form__field-wrapper">
                        <div class="field">
                          <input
                            id="NewsletterForm--{{ section.id }}"
                            type="email"
                            name="contact[email]"
                            class="field__input"
                            value="{{ form.email }}"
                            aria-required="true"
                            autocorrect="off"
                            autocapitalize="off"
                            autocomplete="email"
                            {% if form.errors %}
                              autofocus
                              aria-invalid="true"
                              aria-describedby="ContactFooter-error"
                            {% elsif form.posted_successfully? %}
                              aria-describedby="ContactFooter-success"
                            {% endif %}
                            placeholder="{{ 'newsletter.label' | t }}"
                            required
                          >
                          <label class="field__label" for="NewsletterForm--{{ section.id }}">
                            {{ 'newsletter.label' | t }}
                          </label>
                        </div>

                        <button
                          type="submit"
                          class="footer__newsletter-button"
                          name="commit"
                          aria-label="{{ section.settings.newsletter_button_label | default: 'Subscribe' }}"
                        >
                          {{ section.settings.newsletter_button_label | default: 'Subscribe' }}
                        </button>

                        {%- if form.errors -%}
                          <small class="newsletter-form__message form__message" id="ContactFooter-error">
                            <span class="svg-wrapper">
                              {{- 'icon-error.svg' | inline_asset_content -}}
                            </span>
                            {{- form.errors.translated_fields.email | capitalize }}
                            {{ form.errors.messages.email -}}
                          </small>
                        {%- endif -%}
                      </div>

                      {%- if form.posted_successfully? -%}
                        <h3
                          class="newsletter-form__message newsletter-form__message--success form__message"
                          id="ContactFooter-success"
                          tabindex="-1"
                          autofocus
                        >
                          <span class="svg-wrapper">
                            {{- 'icon-success.svg' | inline_asset_content -}}
                          </span>
                          {{- 'newsletter.success' | t }}
                        </h3>
                      {%- endif -%}
                    {%- endform -%}
                  </div>
                </div>
              {%- endif -%}
            </div>

            {%- if extra_blocks_markup != blank -%}
              <div class="footer__extras">
                {{ extra_blocks_markup }}
              </div>
            {%- endif -%}

            {%- if section.settings.footer_disclaimer != blank or trust_badges != blank -%}
              <div class="footer__midline"></div>
              <div class="footer__meta-row">
                {%- if section.settings.footer_disclaimer != blank -%}
                  <div class="footer__meta-copy">
                    {{ section.settings.footer_disclaimer | escape | newline_to_br }}
                  </div>
                {%- endif -%}

                {%- if trust_badges != blank and section.settings.trust_badges != blank -%}
                  <div class="footer__trust-badges">
                    {%- for badge in trust_badges -%}
                      {%- assign badge_label = badge | strip -%}
                      {%- if badge_label != blank -%}
                        <span class="footer__trust-badge">{{ badge_label }}</span>
                      {%- endif -%}
                    {%- endfor -%}
                  </div>
                {%- endif -%}
              </div>
            {%- endif -%}
          </div>
        </div>
      {%- endunless -%}
    {%- endif -%}

    <div
      class="footer__content-bottom{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
      {% if settings.animations_reveal_on_scroll %}
        data-cascade
      {% endif %}
    >
      <div class="footer__content-bottom-wrapper footer__content-bottom-wrapper--center">
        <div class="footer__column footer__column--info">
          {%- if section.settings.payment_enable -%}
            <div class="footer__payment">
              <span class="visually-hidden">{{ 'sections.footer.payment' | t }}</span>
              <ul class="list list-payment" role="list">
                {%- for type in shop.enabled_payment_types -%}
                  <li class="list-payment__item">
                    {{ type | payment_type_svg_tag: class: 'icon icon--full-color' }}
                  </li>
                {%- endfor -%}
              </ul>
            </div>
          {%- endif -%}
        </div>
      </div>

      <div class="footer__content-bottom-wrapper footer__content-bottom-wrapper--center">
        <div class="footer__copyright caption">
          <small class="copyright__content"
            >&copy; {{ 'now' | date: '%Y' }}, {{ shop.name | link_to: routes.root_url -}}
          </small>

          {%- if section.settings.show_policy -%}
            <ul class="policies list-unstyled">
              {%- for policy in shop.policies -%}
                {%- if policy != blank -%}
                  <li>
                    <small class="copyright__content">
                      <a href="{{ policy.url }}">{{ policy.title | escape }}</a>
                    </small>
                  </li>
                {%- endif -%}
              {%- endfor -%}
            </ul>
          {%- endif -%}
        </div>
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "t:sections.footer.name",
  "blocks": [
    {
      "type": "@app"
    },
    {
      "type": "link_list",
      "name": "t:sections.footer.blocks.link_list.name",
      "settings": [
        {
          "type": "inline_richtext",
          "id": "heading",
          "default": "t:sections.footer.blocks.link_list.settings.heading.default",
          "label": "t:sections.footer.blocks.link_list.settings.heading.label"
        },
        {
          "type": "link_list",
          "id": "menu",
          "default": "footer",
          "label": "t:sections.footer.blocks.link_list.settings.menu.label",
          "info": "t:sections.footer.blocks.link_list.settings.menu.info"
        }
      ]
    },
    {
      "type": "brand_information",
      "name": "t:sections.footer.blocks.brand_information.name",
      "settings": [
        {
          "type": "paragraph",
          "content": "t:sections.footer.blocks.brand_information.settings.paragraph.content"
        },
        {
          "type": "header",
