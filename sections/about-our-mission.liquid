{{ 'about-custom.css' | asset_url | stylesheet_tag }}

<div class="about-mission">
  <div class="page-width">
    <div class="mission-header">
      <h2 class="mission-title">
        {%- assign title_parts = section.settings.section_title | split: ' ' -%}
        {%- for part in title_parts -%}
          {%- if forloop.last -%}
            <span class="highlight-color">{{ part }}</span>
          {%- else -%}
            {{ part }} 
          {%- endif -%}
        {%- endfor -%}
      </h2>
      <p class="mission-subtitle">{{ section.settings.section_subtitle }}</p>
    </div>

    <div class="mission-content">
      <div class="mission-list">
        {%- for block in section.blocks -%}
          <div class="mission-item" {{ block.shopify_attributes }}>
            <div class="mission-number">{{ block.settings.number }}</div>
            <div class="mission-item-content">
              <h3 class="mission-item-title">{{ block.settings.title }}</h3>
              <p class="mission-item-description">{{ block.settings.description }}</p>
            </div>
          </div>
        {%- endfor -%}
      </div>

      <div class="mission-highlights">
        <div class="highlight-box">
          <h3 class="highlight-title">{{ section.settings.highlight_box_title }}</h3>
          <ul class="highlight-list">
            {%- assign items = section.settings.highlight_box_items | split: ',' -%}
            {%- for item in items -%}
              <li>{{ item | strip }}</li>
            {%- endfor -%}
          </ul>
        </div>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "About - Vision Split",
  "settings": [
    {
      "type": "text",
      "id": "section_title",
      "label": "Section Title",
      "default": "Our Vision"
    },
    {
      "type": "textarea",
      "id": "section_subtitle",
      "label": "Section Subtitle",
      "default": "To empower people to take control of their health through scientifically-proven supplements."
    },
    {
      "type": "text",
      "id": "highlight_box_title",
      "label": "Highlight Box Title",
      "default": "Nature & Science Are Perfect Partners"
    },
    {
      "type": "textarea",
      "id": "highlight_box_items",
      "label": "Highlight Items (comma-separated)",
      "default": "Plant-Sourced, Scientifically Tested, Sustainable Sourced, Zero Fillers"
    }
  ],
  "blocks": [
    {
      "type": "mission_item",
      "name": "Point",
      "settings": [
        {
          "type": "text",
          "id": "number",
          "label": "Number",
          "default": "01"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Evidence-Led Formulation"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Every ingredient in our supplements is selected based on scientific research."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "About - Our Vision Split",
      "blocks": [
        {
          "type": "mission_item",
          "settings": {
            "number": "01",
            "title": "Evidence-Led Formulation"
          }
        },
        {
          "type": "mission_item",
          "settings": {
            "number": "02",
            "title": "Certified Botanical Sourcing"
          }
        },
        {
          "type": "mission_item",
          "settings": {
            "number": "03",
            "title": "UK GMP Manufacturing"
          }
        },
        {
          "type": "mission_item",
          "settings": {
            "number": "04",
            "title": "Clean Formulas, Always"
          }
        }
      ]
    }
  ]
}
{% endschema %}

