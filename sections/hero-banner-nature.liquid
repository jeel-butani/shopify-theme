{%- style -%}
  #hero-nature-{{ section.id }} {
    position: relative;
    width: 100%;
    min-height: 520px;
    overflow: hidden;
    display: flex;
    align-items: center;
  }

  #hero-nature-{{ section.id }} .hero-nature__media {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  #hero-nature-{{ section.id }} .hero-nature__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  #hero-nature-{{ section.id }} .hero-nature__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      rgba(0, 30, 10, 0.65) 0%,
      rgba(0, 20, 5, 0.35) 50%,
      rgba(0, 0, 0, 0.15) 100%
    );
    z-index: 1;
  }

  #hero-nature-{{ section.id }} .hero-nature__media {
    background-image: url('{{ "forest-img.png" | asset_url }}');
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
  }

  #hero-nature-{{ section.id }} .hero-nature__content {
    position: relative;
    z-index: 2;
    width: 100%;
    padding: 0 5%; 
    height: 100%; 
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-end;
    text-align: right;
  }

  #hero-nature-{{ section.id }} .hero-nature__text-wrapper {
    max-width: 450px;
  }

  #hero-nature-{{ section.id }} .hero-nature__heading {
    font-family: 'Montserrat', 'Georgia', serif;
    font-size: clamp(32px, 5vw, 56px);
    font-weight: 400;
    line-height: 1.1;
    color: {{ section.settings.heading_color }};
    letter-spacing: -0.02em;
    margin-bottom: 20px;
  }

  #hero-nature-{{ section.id }} .hero-nature__buttons {
    display: flex;
    gap: 14px;
    justify-content: flex-end;
    flex-wrap: wrap;
  }

  #hero-nature-{{ section.id }} .hero-nature__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 12px 28px;
    font-size: 11.5px;
    font-weight: 500;
    text-decoration: none;
    border-radius: 6px;
    transition: all 0.3s ease;
    letter-spacing: 0.03em;
    text-transform: uppercase;
  }

  #hero-nature-{{ section.id }} .hero-nature__btn--primary {
    background: {{ section.settings.button_primary_bg }};
    color: {{ section.settings.button_primary_text }};
    border: 2px solid {{ section.settings.button_primary_bg }};
  }

  #hero-nature-{{ section.id }} .hero-nature__btn--primary:hover {
    background: transparent;
    color: #ffffff;
    border-color: #ffffff;
  }

  #hero-nature-{{ section.id }} .hero-nature__btn--secondary {
    background: transparent;
    color: #ffffff;
    border: 2px solid rgba(255, 255, 255, 0.6);
  }

  #hero-nature-{{ section.id }} .hero-nature__btn--secondary:hover {
    background: rgba(255, 255, 255, 0.15);
    border-color: #ffffff;
  }

  #hero-nature-{{ section.id }} .hero-nature__badges {
    display: flex;
    gap: 32px;
    justify-content: flex-end;
    padding: 24px 0 36px;
  }

  #hero-nature-{{ section.id }} .hero-nature__badge {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
  }

  #hero-nature-{{ section.id }} .hero-nature__badge-value {
    font-size: 22px;
    font-weight: 700;
    color: #ffffff;
    display: flex;
    align-items: center;
    gap: 4px;
    line-height: 1;
  }

  #hero-nature-{{ section.id }} .hero-nature__badge-value .star {
    color: #fbbf24;
    font-size: 18px;
  }

  #hero-nature-{{ section.id }} .hero-nature__badge-label {
    font-size: 11px;
    color: rgba(255, 255, 255, 0.75);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 500;
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    #hero-nature-{{ section.id }} {
      min-height: 420px;
    }

    #hero-nature-{{ section.id }} .hero-nature__content {
      align-items: center;
      text-align: center;
      padding: 40px 5% 0;
    }

    #hero-nature-{{ section.id }} .hero-nature__buttons {
      justify-content: center;
    }

    #hero-nature-{{ section.id }} .hero-nature__badges {
      justify-content: center;
      gap: 20px;
    }

    #hero-nature-{{ section.id }} .hero-nature__text-wrapper {
      max-width: 100%;
    }
  }
{%- endstyle -%}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&display=swap" rel="stylesheet">

<section id="hero-nature-{{ section.id }}">
  <div class="hero-nature__media">
    {{ "forest-img.png" | asset_url | image_url: width: 3840 | image_tag: sizes: '100vw', widths: '375, 750, 1100, 1500, 1780, 2000, 3000, 3840', fetchpriority: 'high' }}
  </div>

  <div class="hero-nature__overlay"></div>

  <div class="hero-nature__content">
    <div class="hero-nature__text-wrapper">
      {%- if section.settings.heading != blank -%}
        <span class="hero-nature__heading">{{ section.settings.heading }}</span>
      {%- endif -%}

      <div class="hero-nature__buttons">
        {%- if section.settings.button_label_1 != blank -%}
          <a href="{{ section.settings.button_link_1 }}" class="hero-nature__btn hero-nature__btn--primary">
            {{ section.settings.button_label_1 }}
          </a>
        {%- endif -%}
        {%- if section.settings.button_label_2 != blank -%}
          <a href="{{ section.settings.button_link_2 }}" class="hero-nature__btn hero-nature__btn--secondary">
            {{ section.settings.button_label_2 }}
          </a>
        {%- endif -%}
      </div>

      <div class="hero-nature__badges">
        {%- if section.settings.badge_1_value != blank -%}
          <div class="hero-nature__badge">
            <span class="hero-nature__badge-value">
              <span class="star">★</span> {{ section.settings.badge_1_value }}
            </span>
            <span class="hero-nature__badge-label">{{ section.settings.badge_1_label }}</span>
          </div>
        {%- endif -%}
        {%- if section.settings.badge_2_value != blank -%}
          <div class="hero-nature__badge">
            <span class="hero-nature__badge-value">{{ section.settings.badge_2_value }}</span>
            <span class="hero-nature__badge-label">{{ section.settings.badge_2_label }}</span>
          </div>
        {%- endif -%}
        {%- if section.settings.badge_3_value != blank -%}
          <div class="hero-nature__badge">
            <span class="hero-nature__badge-value">{{ section.settings.badge_3_value }}</span>
            <span class="hero-nature__badge-label">{{ section.settings.badge_3_label }}</span>
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero Banner Nature",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Restore Your Gut Balance."
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Buttons"
    },
    {
      "type": "text",
      "id": "button_label_1",
      "label": "Button 1 label",
      "default": "SAFE SUPPLEMENTS"
    },
    {
      "type": "url",
      "id": "button_link_1",
      "label": "Button 1 link"
    },
    {
      "type": "color",
      "id": "button_primary_bg",
      "label": "Button 1 background",
      "default": "#2d7a3a"
    },
    {
      "type": "color",
      "id": "button_primary_text",
      "label": "Button 1 text color",
      "default": "#ffffff"
    },
    {
      "type": "text",
      "id": "button_label_2",
      "label": "Button 2 label",
      "default": "GET 20% OFF"
    },
    {
      "type": "url",
      "id": "button_link_2",
      "label": "Button 2 link"
    },
    {
      "type": "header",
      "content": "Trust Badges"
    },
    {
      "type": "text",
      "id": "badge_1_value",
      "label": "Badge 1 value",
      "default": "4.9+"
    },
    {
      "type": "text",
      "id": "badge_1_label",
      "label": "Badge 1 label",
      "default": "Rating"
    },
    {
      "type": "text",
      "id": "badge_2_value",
      "label": "Badge 2 value",
      "default": "12K+"
    },
    {
      "type": "text",
      "id": "badge_2_label",
      "label": "Badge 2 label",
      "default": "Happy Customers"
    },
    {
      "type": "text",
      "id": "badge_3_value",
      "label": "Badge 3 value",
      "default": "100%"
    },
    {
      "type": "text",
      "id": "badge_3_label",
      "label": "Badge 3 label",
      "default": "Natural"
    }
  ],
  "presets": [
    {
      "name": "Hero Banner Nature"
    }
  ]
}
{% endschema %}
