{{ 'about-custom.css' | asset_url | stylesheet_tag }}

<div class="about-vision">
  <div class="page-width">
    <div class="vision-header">
      <h2 class="vision-title">
        {%- assign title_parts = section.settings.section_title | split: ' ' -%}
        {%- for part in title_parts -%}
          {%- if forloop.last -%}
            <span class="highlight-color">{{ part }}</span>
          {%- else -%}
            {{ part }} 
          {%- endif -%}
        {%- endfor -%}
      </h2>
      <p class="vision-subtitle">{{ section.settings.section_subtitle }}</p>
    </div>

    <div class="vision-cards">
      {%- for block in section.blocks -%}
        <div class="vision-card" {{ block.shopify_attributes }}>
          <div class="card-icon-wrapper">
            {%- if block.settings.icon_svg != blank -%}
              {{ block.settings.icon_svg }}
            {%- elsif block.settings.icon_image != blank -%}
              {{ block.settings.icon_image | image_url: width: 60 | image_tag: width: 30, height: 30 }}
            {%- else -%}
              {{- 'icon-leaf.svg' | inline_asset_content -}}
            {%- endif -%}
          </div>
          <div class="card-number">{{ block.settings.card_number }}</div>
          <h3 class="card-title">{{ block.settings.card_title }}</h3>
          <p class="card-description">{{ block.settings.card_description }}</p>
        </div>
      {%- endfor -%}
    </div>

    {%- if section.settings.quote_text != blank -%}
      <div class="vision-quote">
        <div class="quote-text">{{ section.settings.quote_text }}</div>
        {%- if section.settings.quote_author != blank -%}
          <p class="quote-author">— {{ section.settings.quote_author }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "About - Vision/Mission",
  "settings": [
    {
      "type": "text",
      "id": "section_title",
      "label": "Section Title",
      "default": "Our Mission"
    },
    {
      "type": "textarea",
      "id": "section_subtitle",
      "label": "Section Subtitle",
      "default": "We envision a world where every person has access to the highest-quality, naturally sourced supplements."
    },
    {
      "type": "richtext",
      "id": "quote_text",
      "label": "Quote Text",
      "default": "<p>\"The future of wellness is one where science and nature speak the same language — where a supplement bottle is a promise you can trust.\"</p>"
    },
    {
      "type": "text",
      "id": "quote_author",
      "label": "Quote Author",
      "default": "The WellScience Team"
    }
  ],
  "blocks": [
    {
      "type": "vision_card",
      "name": "Card",
      "settings": [
        {
          "type": "html",
          "id": "icon_svg",
          "label": "Icon SVG (optional)"
        },
        {
          "type": "image_picker",
          "id": "icon_image",
          "label": "Icon Image (if SVG is empty)"
        },
        {
          "type": "text",
          "id": "card_number",
          "label": "Card Number",
          "default": "01"
        },
        {
          "type": "text",
          "id": "card_title",
          "label": "Card Title",
          "default": "Science Without Compromise"
        },
        {
          "type": "textarea",
          "id": "card_description",
          "label": "Card Description",
          "default": "We believe in rigorous scientific standards and evidence-based formulations."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "About - Our Mission Top",
      "blocks": [
        {
          "type": "vision_card",
          "settings": {
            "card_number": "01",
            "card_title": "Science Without Compromise"
          }
        },
        {
          "type": "vision_card",
          "settings": {
            "card_number": "02",
            "card_title": "A Healthier Planet"
          }
        },
        {
          "type": "vision_card",
          "settings": {
            "card_number": "03",
            "card_title": "Radical Transparency"
          }
        }
      ]
    }
  ]
}
{% endschema %}

