{{ 'section-about-our-vision.css' | asset_url | stylesheet_tag }}

<div class="about-vision">
  <div class="page-width">
    <div class="vision-header">
      <h2 class="vision-title">{{ section.settings.section_title | split: ' ' | slice: 0, -1 | join: ' ' }}<span class="highlight-color">{{ section.settings.section_title | split: ' ' | last }}</span></h2>
      <p class="vision-subtitle">{{ section.settings.section_subtitle }}</p>
    </div>

    <div class="vision-cards">
      {%- for block in section.blocks -%}
        <div class="vision-card">
          <div class="card-number">{{ block.settings.card_number }}</div>
          <h3 class="card-title">{{ block.settings.card_title }}</h3>
          <p class="card-description">{{ block.settings.card_description }}</p>
        </div>
      {%- endfor -%}
    </div>

    {%- if section.settings.quote_text != blank -%}
      <div class="vision-quote">
        <p class="quote-text">{{ section.settings.quote_text }}</p>
        <p class="quote-author">{{ section.settings.quote_author }}</p>
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Our Vision",
  "settings": [
    {
      "type": "text",
      "id": "section_title",
      "label": "Section Title",
      "default": "Our Vision"
    },
    {
      "type": "textarea",
      "id": "section_subtitle",
      "label": "Section Subtitle",
      "default": "We envision a world where every person has access to the highest-quality, naturally sourced supplements that work harmoniously with their body."
    },
    {
      "type": "richtext",
      "id": "quote_text",
      "label": "Quote Text",
      "default": "<p>\"The future of wellness is one where science and nature speak the same language — where a supplement bottle is a promise you can trust, not a label you need to decode.\"</p>"
    },
    {
      "type": "text",
      "id": "quote_author",
      "label": "Quote Author"
    }
  ],
  "blocks": [
    {
      "type": "vision_card",
      "name": "Vision Card",
      "settings": [
        {
          "type": "text",
          "id": "card_number",
          "label": "Card Number",
          "default": "01"
        },
        {
          "type": "text",
          "id": "card_title",
          "label": "Card Title",
          "default": "Science Without Compromise"
        },
        {
          "type": "textarea",
          "id": "card_description",
          "label": "Card Description",
          "default": "We believe in rigorous scientific standards and evidence-based formulations that deliver real results."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "About - Our Vision",
      "blocks": [
        {
          "type": "vision_card",
          "settings": {
            "card_number": "01",
            "card_title": "Science Without Compromise",
            "card_description": "We believe in rigorous scientific standards and evidence-based formulations that deliver real results."
          }
        },
        {
          "type": "vision_card",
          "settings": {
            "card_number": "02",
            "card_title": "A Healthier Planet",
            "card_description": "Sustainability and environmental responsibility are at the heart of everything we do."
          }
        },
        {
          "type": "vision_card",
          "settings": {
            "card_number": "03",
            "card_title": "Radical Transparency",
            "card_description": "We believe you deserve to know exactly what's in your supplements and why it matters."
          }
        }
      ]
    }
  ]
}
{% endschema %}

<style>
.about-vision {
  padding: 60px 20px;
}

.vision-header {
  text-align: center;
  margin-bottom: 60px;
}

.vision-title {
  font-size: 36px;
  font-weight: 600;
  margin-bottom: 20px;
  color: #333;
}

.vision-title .highlight-color {
  color: #00c9a7;
}

.vision-subtitle {
  font-size: 16px;
  color: #666;
  max-width: 600px;
  margin: 0 auto;
}

.vision-cards {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
  gap: 30px;
  margin-bottom: 60px;
}

.vision-card {
  border: 1px solid #ddd;
  border-radius: 12px;
  padding: 30px;
  text-align: center;
  background: #fff;
}

.card-number {
  font-size: 48px;
  font-weight: 700;
  color: #333;
  margin-bottom: 20px;
}

.card-title {
  font-size: 18px;
  font-weight: 600;
  margin-bottom: 15px;
  color: #333;
}

.card-description {
  font-size: 14px;
  color: #666;
  line-height: 1.6;
}

.vision-quote {
  background: #f9f9f9;
  border: 1px solid #ddd;
  border-radius: 12px;
  padding: 30px;
  text-align: center;
}

.quote-text {
  font-size: 16px;
  color: #666;
  font-style: italic;
  margin-bottom: 10px;
  line-height: 1.8;
}

.quote-author {
  font-size: 14px;
  color: #999;
}
</style>
