{%- comment -%} HTML {%- endcomment -%}
<section id="DP--{{ section_id }}" class="DP--{{ section_id }} wbs-pck__videos-slider wbs-pck__section">
  {%- if section.settings.anchor_id != blank -%}
    <div id="{{ section.settings.anchor_id | remove: '#' | handleize }}" class="wbs-pck__anchor-id" style="height:0;overflow:hidden;"></div>
  {%- endif -%}

  {%- comment -%} Title: last word gets blue italic, rest get green {%- endcomment -%}
  {% assign words = section.settings.title | split: ' ' %}
  <div class="tittle-wrap">
    <h2 class="title">
      {% for word in words %}
        {% if forloop.last %}
          <em class="blue">{{ word }}</em>
        {% else %}
          <span class="green">{{ word }}</span>
        {% endif %}
      {% endfor %}
    </h2>
  </div>

  <div class="wbs-pck__sizer">
    <div class="wbs-pck__flex wbs-pck__flex--main">
      <div class="wbs-pck__videos">
        <div id="slider-{{ section_id }}" class="wbs-pck__videos-wrapper wbs-pck__video-slider">

          {%- for block in videos -%}
            <div class="wbs-pck__item wbs-pck__video-{{ forloop.index }} wbs-pck__block-{{ block.id }}" {{ block.shopify_attributes }}>
              <div class="wbs-pck__video">
                <div class="wbs-pck__video-inner">

                  {%- if block.settings.html5_video != blank -%}
                    {%- assign video = block.settings.html5_video -%}
                    <div class="wbs-pck__video-wrapper">
                      <video class="wbs-pck__hosted-video"
                        width="{{ video.aspect_ratio | times: 100 }}"
                        height="100"
                        playsinline loop muted loading="lazy"
                        poster="{{ video.preview_image | image_url: width: 2800 }}">
                        {%- for source in video.sources -%}
                          {%- if source.format == 'mp4' or source.format == 'mov' -%}
                            <source src="{{ source.url }}">
                          {%- endif -%}
                        {%- endfor -%}
                      </video>

                      {%- comment -%} Sound toggle button {%- endcomment -%}
                      <div class="wbs-pck__sound-button"></div>

                      {%- comment -%} Play button overlay (hidden on selected/playing slide) {%- endcomment -%}
                      <div class="wbs-pck__play-overlay">
                        <svg width="50" height="50" viewBox="0 0 50 50" fill="none" xmlns="http://www.w3.org/2000/svg">
                          <circle cx="25" cy="25" r="25" fill="white" fill-opacity="0.85"/>
                          <polygon points="20,14 40,25 20,36" fill="#444"/>
                        </svg>
                      </div>

                      {%- comment -%} Product / collection info — overlaid at bottom of video {%- endcomment -%}
                      {%- unless block.settings.product == blank and block.settings.collection == blank -%}
                        {%- assign collection = collections[block.settings.collection] -%}
                        <div class="wbs-pck__video-content">
                          <a href="{{ block.settings.product.url | default: collection.url }}" class="wbs-pck__absolute-link"></a>

                          {%- assign image = block.settings.product.featured_image | default: collection.featured_image -%}
                          {%- if image != blank -%}
                            {%- if section.settings.image_crop == 'none' -%}
                              {%- assign image_crop_width = image.width -%}
                              {%- assign image_crop_height = image.height -%}
                            {%- endif -%}
                            <div class="wbs-pck__image">
                              <div class="wbs-pck__image__wrapper">
                                <svg class="wbs-pck__svg-sizer" viewBox="0 0 {{ image_crop_width | default: 1000 }} {{ image_crop_height | default: 1000 }}"></svg>
                                {%- capture sizes -%}(max-width: 480px) 48px, 48px{%- endcapture -%}
                                {{ image | image_url: width: 200 | image_tag: widths: '48, 96, 200', sizes: sizes }}
                              </div>
                            </div>
                          {%- endif -%}

                          <div class="wbs-pck__text-area">
                            <p class="wbs-pck__product-name">{{ block.settings.product.title | default: collection.title }}</p>
                            {%- if block.settings.product.price -%}
                              <p class="wbs-pck__product-price">{{ block.settings.product.price | money }}</p>
                            {%- endif -%}
                          </div>
                        </div>
                      {%- endunless -%}
                    </div>

                  {%- else -%}
                    {%- comment -%} Placeholder video (no video uploaded yet) {%- endcomment -%}
                    <div class="wbs-pck__video-wrapper">
                      <video class="wbs-pck__hosted-video" width="2000" height="100" playsinline loop muted loading="lazy">
                        <source src="https://cdn.shopify.com/videos/c/o/v/{{ background_placeholder_video_id }}.mp4" data-wbs-pck-default-src>
                      </video>
                      <div class="wbs-pck__sound-button"></div>
                      <div class="wbs-pck__play-overlay">
                        <svg width="50" height="50" viewBox="0 0 50 50" fill="none" xmlns="http://www.w3.org/2000/svg">
                          <circle cx="25" cy="25" r="25" fill="white" fill-opacity="0.85"/>
                          <polygon points="20,14 40,25 20,36" fill="#444"/>
                        </svg>
                      </div>
                    </div>
                  {%- endif -%}

                </div>
              </div>
            </div>
          {%- endfor -%}

        </div>

        {%- if section.settings.show_arrows != blank -%}
          <div class="wbs-pck__videos-nav">
            <div class="wbs-pck__nav-button wbs-pck__nav-button--prev">
              <svg width="24" height="24" xmlns="http://www.w3.org/2000/svg" fill-rule="evenodd" clip-rule="evenodd">
                <path d="M12 0c6.623 0 12 5.377 12 12s-5.377 12-12 12-12-5.377-12-12 5.377-12 12-12zm0 1c6.071 0 11 4.929 11 11s-4.929 11-11 11-11-4.929-11-11 4.929-11 11-11zm3 5.753l-6.44 5.247 6.44 5.263-.678.737-7.322-6 7.335-6 .665.753z" fill="{{ section.settings.border_color }}"/>
              </svg>
            </div>
            <div class="wbs-pck__nav-button wbs-pck__nav-button--next">
              <svg width="24" height="24" xmlns="http://www.w3.org/2000/svg" fill-rule="evenodd" clip-rule="evenodd">
                <path d="M12 0c6.623 0 12 5.377 12 12s-5.377 12-12 12-12-5.377-12-12 5.377-12 12-12zm0 1c6.071 0 11 4.929 11 11s-4.929 11-11 11-11-4.929-11-11 4.929-11 11-11zm-3 5.753l6.44 5.247-6.44 5.263.678.737 7.322-6-7.335-6-.665.753z" fill="{{ section.settings.border_color }}"/>
              </svg>
            </div>
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>
{%- endcapture -%}
{{ minify | strip_newlines }}

