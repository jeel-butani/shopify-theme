{% schema %}
{
  "name": "Trust badge bar",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "container_width",
      "min": 800,
      "max": 1600,
      "step": 100,
      "unit": "px",
      "label": "Container width",
      "default": 1200
    },
    {
      "type": "range",
      "id": "padding_vertical",
      "min": 8,
      "max": 60,
      "step": 4,
      "unit": "px",
      "label": "Vertical padding",
      "default": 16
    },
    {
      "type": "range",
      "id": "item_spacing",
      "min": 8,
      "max": 60,
      "step": 4,
      "unit": "px",
      "label": "Space between items",
      "default": 32
    },
    {
      "type": "select",
      "id": "icon_position",
      "label": "Icon position",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "top",
          "label": "Top"
        }
      ],
      "default": "left"
    },
    {
      "type": "select",
      "id": "mobile_layout",
      "label": "Mobile layout",
      "options": [
        {
          "value": "scroll",
          "label": "Horizontal scroll"
        },
        {
          "value": "stack",
          "label": "Stack vertically"
        }
      ],
      "default": "scroll"
    },
    {
      "type": "header",
      "content": "Icon style"
    },
    {
      "type": "range",
      "id": "icon_size",
      "min": 20,
      "max": 60,
      "step": 4,
      "unit": "px",
      "label": "Icon size",
      "default": 32
    },
    {
      "type": "range",
      "id": "icon_text_gap",
      "min": 4,
      "max": 24,
      "step": 2,
      "unit": "px",
      "label": "Gap between icon and text",
      "default": 12
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon color",
      "default": "#4a5344"
    },
