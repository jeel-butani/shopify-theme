{% doc %}
  @prompt
    Create a Shopify section similar to a horizontal trust badge bar.
    
    Requirements:
    
    1. Section Type:
    - Custom section (Liquid)
    - Should behave like a "multicolumn" style layout
    
    2. Layout:
    - Full width section
    - Center aligned content
    - Display 4 to 5 items in a single horizontal row (desktop)
    - Stack or scroll horizontally on mobile
    
    3. Each Item Should Contain:
    - Small icon (SVG or image)
    - Title text (short, bold)
    - Optional subtitle (small text below)
    
    4. Example Content:
    - Free UK Shipping
    - 30-Day Returns
    - Secure Checkout
    - 4.9 / 5 Stars
    - GMP Certified Manufacturing
    
    5. Styling:
    - Background: light neutral or slightly tinted (e.g. #f8faf6)
    - Items evenly spaced with flexbox
    - Icons placed above or left of text
    - Text aligned center
    - Clean modern spacing (padding top/bottom ~12–20px)
    
    6. Responsiveness:
    - Desktop: 4–5 columns in one row
    - Tablet: 2–3 per row
    - Mobile: horizontal scroll OR stacked
    
    7. Schema Settings:
    - Allow adding/removing items (blocks)
    - Each block should have:
      - icon (image picker or SVG)
      - title (text)
      - subtitle (text optional)
    - Section settings:
      - background color
      - text color
    
    8. Class Naming:
    - Use clean classes like:
      .trust-bar
      .trust-item
      .trust-icon
      .trust-text
    
    9. Performance:
    - Use flexbox (not grid-heavy)
    - Avoid inline styles
    
    Goal:
    Create a reusable trust badge strip similar to ecommerce stores highlighting shipping, returns, and certifications.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .trust-bar-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.padding_vertical }}px 0;
  }

  .trust-bar__container-{{ ai_gen_id }} {
    max-width: {{ block.settings.container_width }}px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .trust-bar__items-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: {{ block.settings.item_spacing }}px;
    flex-wrap: wrap;
  }

  .trust-item-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: {{ block.settings.icon_text_gap }}px;
    flex-direction: {% if block.settings.icon_position == 'top' %}column{% else %}row{% endif %};
    text-align: {% if block.settings.icon_position == 'top' %}center{% else %}left{% endif %};
    flex: 1 1 auto;
    min-width: 150px;
    max-width: 165px;
  }

  .trust-icon-{{ ai_gen_id }} {
    flex-shrink: 0;
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .trust-icon-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .trust-icon-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    fill: {{ block.settings.icon_color }};
  }

  .trust-text-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .trust-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    font-weight: 600;
    color: {{ block.settings.text_color }};
    margin: 0;
    line-height: 1.2;
  }

  .trust-subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtitle_size }}px;
    color: {{ block.settings.text_color }};
    opacity: 0.8;
    margin: 0;
    line-height: 1.3;
  }

  @media screen and (max-width: 989px) {
    .trust-bar__items-{{ ai_gen_id }} {
      gap: {{ block.settings.item_spacing | times: 0.8 }}px;
    }

    .trust-item-{{ ai_gen_id }} {
      min-width: 120px;
    }

    .trust-icon-{{ ai_gen_id }} {
      width: {{ block.settings.icon_size | times: 0.8 }}px;
      height: {{ block.settings.icon_size | times: 0.8 }}px;
    }

    .trust-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.9 }}px;
    }

    .trust-subtitle-{{ ai_gen_id }} {
      font-size: {{ block.settings.subtitle_size | times: 0.9 }}px;
    }
  }

  @media screen and (max-width: 749px) {
    .trust-bar-{{ ai_gen_id }} {
      padding: {{ block.settings.padding_vertical | times: 0.8 }}px 0;
    }

    {% if block.settings.mobile_layout == 'scroll' %}
      .trust-bar__items-{{ ai_gen_id }} {
        flex-wrap: nowrap;
        overflow-x: auto;
        justify-content: flex-start;
        -webkit-overflow-scrolling: touch;
        scrollbar-width: none;
        padding-bottom: 8px;
      }

      .trust-bar__items-{{ ai_gen_id }}::-webkit-scrollbar {
        display: none;
      }

      .trust-item-{{ ai_gen_id }} {
        flex-shrink: 0;
      }
    {% else %}
      .trust-bar__items-{{ ai_gen_id }} {
        flex-direction: column;
        gap: 16px;
      }

      .trust-item-{{ ai_gen_id }} {
        max-width: 100%;
        width: 100%;
      }
    {% endif %}
  }
{% endstyle %}

