{% doc %}
  @prompt
    Create a Shopify section that displays collection categories as horizontal filter chips.
    
    Requirements:
    
    1. Layout:
    - Full width horizontal bar
    - Center aligned
    - Scrollable horizontally on mobile
    
    2. Items:
    - Each item represents a collection
    - Display as rounded pills (chips)
    
    3. Example Items:
    - All Products
    - Gut & Digestive
    - Immunity & Defence
    - Detox & Cleanse
    - Vitality & Energy
    - Weight & Fitness
    - Bundles
    
    4. Design:
    - Rounded buttons (border-radius: 999px)
    - Light background (e.g. #f3f5f2)
    - Active item highlighted (dark green background, white text)
    - Small padding inside (8px 16px)
    
    5. Interaction:
    - Each chip links to its collection page
    - Active state based on current collection
    
    6. Schema:
    - Blocks = collections
    - Each block:
      - collection picker
      - custom label (optional)
    
    7. Classes:
    - .collection-filter-bar
    - .filter-chip
    - .active
    
    Goal:
    Replicate modern ecommerce category filter pills like in premium Shopify themes.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .collection-filter-bar-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    overflow-x: auto;
    overflow-y: hidden;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding: {{ block.settings.vertical_padding }}px 0;
    background: #222E22;
  }

  .collection-filter-bar-{{ ai_gen_id }}::-webkit-scrollbar {
    display: none;
  }

  .collection-filter-bar__wrapper-{{ ai_gen_id }} {
    display: flex;
    justify-content: {{ block.settings.alignment }};
    align-items: center;
    gap: {{ block.settings.chip_spacing }}px;
    min-width: min-content;
    padding: 0 {{ block.settings.horizontal_padding }}px;
  }

  .filter-chip-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: {{ block.settings.chip_padding_vertical }}px {{ block.settings.chip_padding_horizontal }}px;
    background-color: {{ block.settings.chip_background }};
    color: {{ block.settings.chip_text_color }};
    border-radius: 999px;
    text-decoration: none;
    white-space: nowrap;
    font-size: {{ block.settings.chip_font_size }}px;
    font-weight: {{ block.settings.chip_font_weight }};
    transition: all 0.3s ease;
    border: {{ block.settings.chip_border_width }}px solid {{ block.settings.chip_border_color }};
  }

  .filter-chip-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.chip_hover_background }};
    color: {{ block.settings.chip_hover_text_color }};
    border-color: {{ block.settings.chip_hover_border_color }};
  }

  .filter-chip-{{ ai_gen_id }}.active {
    background-color: {{ block.settings.chip_active_background }};
    color: {{ block.settings.chip_active_text_color }};
    border-color: {{ block.settings.chip_active_border_color }};
  }

  @media screen and (max-width: 749px) {
    .collection-filter-bar__wrapper-{{ ai_gen_id }} {
      justify-content: flex-start;
    }
  }
{% endstyle %}

<collection-filter-bar-{{ ai_gen_id }} class="collection-filter-bar-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="collection-filter-bar__wrapper-{{ ai_gen_id }}">
    {% if block.settings.show_all_products %}
      <a
        href="/collections/all"
        class="filter-chip-{{ ai_gen_id }}"
        data-collection-handle="all"
      >
        {{ block.settings.all_products_label }}
      </a>
    {% endif %}

    {% for i in (1..10) %}
      {% liquid
        assign collection_key = 'collection_' | append: i
        assign label_key = 'label_' | append: i
        assign collection = block.settings[collection_key]
        assign custom_label = block.settings[label_key]

        if collection != blank
          if custom_label != blank
            assign label = custom_label
          else
            assign label = collection.title
          endif
        endif
      %}

      {% if collection != blank %}
        <a
          href="{{ collection.url }}"
          class="filter-chip-{{ ai_gen_id }}"
          data-collection-handle="{{ collection.handle }}"
        >
          {{ label }}
        </a>
      {% endif %}
    {% endfor %}
  </div>
</collection-filter-bar-{{ ai_gen_id }}>

<script>
  (function() {
    class CollectionFilterBar{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.setActiveChip();
      }

      setActiveChip() {
        const currentPath = window.location.pathname;
        const chips = this.querySelectorAll('.filter-chip-{{ ai_gen_id }}');

        chips.forEach(chip => {
          chip.classList.remove('active');
          const chipUrl = chip.getAttribute('href');

          if (currentPath === chipUrl || (currentPath.includes('/collections/') && chipUrl.includes(currentPath))) {
            chip.classList.add('active');
          }
        });

        if (!this.querySelector('.filter-chip-{{ ai_gen_id }}.active') && chips.length > 0) {
          chips[0].classList.add('active');
        }
      }
    }

    customElements.define('collection-filter-bar-{{ ai_gen_id }}', CollectionFilterBar{{ ai_gen_id }});
  })();
</script>

